#HELIUS_WEBHOOK_ENABLED=true

# Alchemy Webhook Configuration
ALCHEMY_SIGNING_KEY=

# Settlement relayer
# Accepts either a solana-keygen JSON array or an absolute path to the JSON file.
SETTLEMENT_RELAYER_KEYPAIR=
# Optional static Address Lookup Table ids for settlement v0 tx.
# Comma-separated when you use more than one table.
# Example:
# SETTLEMENT_STATIC_ALT_IDS=4AJVrxuTMPJDG1Rt4Q8KNU7C3W1qXEYzFuVdsNPyo2JK
SETTLEMENT_STATIC_ALT_IDS=

# Faucet configuration:
# - Both values accept either a solana-keygen JSON array, or a file path to that JSON.
# - The payer pays transaction fees; the mint authority must be the mint's authority.
FAUCET_PAYER_KEYPAIR=
FAUCET_MINT_AUTHORITY_KEYPAIR=
# Faucet amount in whole tokens (base-units = amount * 10^decimals).
FAUCET_AMOUNT=500
# Temporary: disable faucet wallet/IP 24h cooldown for debugging.
FAUCET_DISABLE_RATE_LIMIT=true


