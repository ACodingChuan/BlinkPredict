PORT=8080

# Postgres (split fields; backend will build the connection URL)
DB_HOST=localhost
DB_PORT=5432
APP_DB=blinkpredict
APP_DB_USER=predict_app
APP_DB_PASSWORD=
DB_SSLMODE=disable

# Solana cluster RPC (localnet/devnet)
SOLANA_RPC_URL=http://127.0.0.1:8899

# vUSDC mint (fill this after you create the SPL token mint)
VUSDC_MINT=
VUSDC_DECIMALS=6

# Faucet configuration:
# - Both values accept either a solana-keygen JSON array, or a file path to that JSON.
# - The payer pays transaction fees; the mint authority must be the mint's authority.
FAUCET_PAYER_KEYPAIR=/path/to/payer.json
FAUCET_MINT_AUTHORITY_KEYPAIR=/path/to/mint-authority.json

# Faucet amount in whole tokens (base-units = amount * 10^decimals).
FAUCET_AMOUNT=500
