PORT=8080
LOG_LEVEL=info
AUTH_TOKEN_SECRET=replace-with-a-long-random-string
ADMIN_EMAILS=
ADMIN_WALLETS=

# Postgres
DB_HOST=127.0.0.1
DB_PORT=5432
APP_DB=blinkpredict
APP_DB_USER=blinkpredict
APP_DB_PASSWORD=change_me
DB_SSLMODE=disable
# Optional fallback if you prefer a single DSN instead of DB_* fields.
# DATABASE_URL=postgres://blinkpredict:change_me@127.0.0.1:5432/blinkpredict?sslmode=disable

# NATS JetStream
NATS_URL=nats://127.0.0.1:4222
NATS_JS_DOMAIN=
NATS_STREAM_CMD=AP_CMD
NATS_STREAM_EVT=AP_EVT
NATS_STREAM_WHK=AP_WHK

# Redis read model / writer cache
REDIS_URL=redis://127.0.0.1:6379/1

# Matcher batching
MATCHER_TICK_INTERVAL=1s
MATCHER_BATCH_MAX_FILLS=64
MATCHER_BATCH_MAX_ORDERS=96
MATCHER_BATCH_MAX_BYTES=262144
MATCHER_BATCH_MAX_AGE_MS=40
MATCHER_BATCH_IDLE_FLUSH_MS=15
MATCHER_BATCH_FLUSH_TICK_MS=10
ORDERBOOK_DEPTH_LEVELS=20

# Solana + program
SOLANA_RPC_URL=http://127.0.0.1:8899
PROGRAM_ID=REPLACE_WITH_DEPLOYED_PROGRAM_ID
VUSDC_MINT=REPLACE_WITH_VUSDC_MINT
GLOBAL_VAULT=REPLACE_WITH_GLOBAL_VAULT_PDA
VUSDC_DECIMALS=6

# Settlement relayer
# Accepts either a solana-keygen JSON array or an absolute path to the JSON file.
SETTLEMENT_RELAYER_KEYPAIR=/absolute/path/to/relayer.json

# Faucet
# Accepts either a solana-keygen JSON array or an absolute path to the JSON file.
FAUCET_PAYER_KEYPAIR=/absolute/path/to/payer.json
FAUCET_MINT_AUTHORITY_KEYPAIR=/absolute/path/to/mint-authority.json
FAUCET_AMOUNT=500
FAUCET_DISABLE_RATE_LIMIT=false

# Helius deposit webhook (optional)
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=
HELIUS_WEBHOOK_ENABLED=false

# Alchemy settlement / market webhook signature verification (optional)
ALCHEMY_SIGNING_KEY=
