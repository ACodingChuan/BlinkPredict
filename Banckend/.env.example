PORT=8080
LOG_LEVEL=info

AUTH_TOKEN_SECRET=

# Postgres (split fields; backend will build the connection URL)
DB_HOST=
DB_PORT=
APP_DB=blinkpredict
APP_DB_USER=predict_app
APP_DB_PASSWORD=
DB_SSLMODE=

# NATS JetStream
NATS_URL=
NATS_JS_DOMAIN=
NATS_STREAM_CMD=AP_CMD
NATS_STREAM_EVT=AP_EVT
NATS_STREAM_WHK=AP_WHK

# Redis read model (required for writer rebuild + hot query path)
REDIS_URL=

MATCHER_MARKET_MAX_FILLS_HOT=64
MATCHER_MARKET_MAX_FILLS_COLD=16

# Matcher batching
MATCHER_TICK_INTERVAL=600s
MATCHER_BATCH_MAX_FILLS=64
MATCHER_BATCH_MAX_ORDERS=96
MATCHER_BATCH_MAX_BYTES=262144
MATCHER_BATCH_MAX_AGE_MS=40
MATCHER_BATCH_IDLE_FLUSH_MS=15
MATCHER_BATCH_FLUSH_TICK_MS=10
MATCHER_CHECKPOINT_INTERVAL=100ms

# Solana cluster RPC (localnet/devnet)
SOLANA_RPC_URL=
SOLANA_WS_URL=
