SETTLEMENT_SCHEDULER_FALLBACK_SCAN=300ms
SETTLEMENT_SUBMITTED_STATUS_POLL=15s
SETTLEMENT_SUBMITTED_REBROADCAST=8s
SETTLEMENT_SUBMITTED_BLOCK_POLL=15s
SETTLEMENT_TERMINAL_POLL_INTERVAL=12s
SETTLEMENT_TERMINAL_POLL_BATCH_SIZE=128
SETTLEMENT_BLOCKHASH_POLL_INTERVAL=15s
SETTLEMENT_BLOCKHASH_MAX_CACHE_AGE=45s
SETTLEMENT_SEND_SKIP_PREFLIGHT=true
SETTLEMENT_TX_MAX_BYTES=1232
