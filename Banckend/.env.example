PORT=8080
LOG_LEVEL=info

# Postgres (split fields; backend will build the connection URL)
# Required for market metadata APIs.
DB_HOST=localhost
DB_PORT=5432
APP_DB=blinkpredict
APP_DB_USER=predict_app
APP_DB_PASSWORD=
DB_SSLMODE=disable

# NATS JetStream
NATS_URL=nats://localhost:4222
NATS_JS_DOMAIN=
NATS_STREAM_CMD=AP_CMD
NATS_STREAM_EVT=AP_EVT

# Redis read model
# Required for writer rebuilds, orderbook hot reads, open orders, recent trades, and price history.
REDIS_URL=redis://localhost:6379/0

# Matcher periodic expiry sweep. Set 0s to disable runtime loop (bootstrap tick still runs).
MATCHER_TICK_INTERVAL=1s

# Read-side API
ORDERBOOK_DEPTH_LEVELS=20

# Solana cluster RPC (localnet/devnet)
SOLANA_RPC_URL=http://127.0.0.1:8899

# vUSDC mint (fill this after you create the SPL token mint)
VUSDC_MINT=
VUSDC_DECIMALS=6


# Faucet configuration:
# - Both values accept either a solana-keygen JSON array, or a file path to that JSON.
# - The payer pays transaction fees; the mint authority must be the mint's authority.
FAUCET_PAYER_KEYPAIR=/path/to/payer.json
FAUCET_MINT_AUTHORITY_KEYPAIR=/path/to/mint-authority.json

# Faucet amount in whole tokens (base-units = amount * 10^decimals).
FAUCET_AMOUNT=500

# Set true to disable 24h wallet/IP cooldown checks (useful for local testing only).
FAUCET_DISABLE_RATE_LIMIT=false

# Alchemy Webhook (get signing key from Alchemy dashboard > Webhooks)
ALCHEMY_SIGNING_KEY=
